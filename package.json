{
  "name": "planet-editor",
  "version": "0.1.1",
  "type": "module",
  "description": "A batteries-included Planet rich-text editor for React, Next.js, and standalone HTML — with font sizing, tables, and resizable images.",
  "license": "MIT",
  "author": "umarzahid028",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/umarzahid028/planet-editor.git"
  },
  "homepage": "https://github.com/umarzahid028/planet-editor#readme",
  "bugs": {
    "url": "https://github.com/umarzahid028/planet-editor/issues"
  },
  "keywords": [
    "planet",
    "editor",
    "rich-text",
    "wysiwyg",
    "react",
    "nextjs",
    "web-component"
  ],
  "main": "./dist/lib/index.js",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/lib/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist/lib",
    "dist/web-component",
    "LICENSE",
    "THIRD-PARTY-LICENSES.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib/lib/index.d.ts",
      "import": "./dist/lib/index.js"
    },
    "./styles.css": "./dist/lib/styles.css",
    "./web-component": "./dist/web-component/planet-editor.js",
    "./web-component.css": "./dist/web-component/planet-editor.css"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@floating-ui/react": "^0.27.19",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-horizontal-rule": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-list": "^3.27.1",
    "@tiptap/extension-subscript": "^3.27.1",
    "@tiptap/extension-superscript": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extension-typography": "^3.27.1",
    "@tiptap/extensions": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash.throttle": "^4.1.1",
    "react-hotkeys-hook": "^5.3.2"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:wc": "vite build --config vite.webcomponent.config.ts",
    "build:html": "node scripts/build-standalone-html.mjs",
    "build:standalone": "npm run build:wc && npm run build:html",
    "build:all": "npm run build:lib && npm run build:wc && npm run build:html",
    "prepublishOnly": "npm run build:lib && npm run build:wc && npm run build:html",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3"
  }
}
